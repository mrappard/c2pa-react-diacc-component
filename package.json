{
  "name": "c2pa-react-diacc-component",
  "version": "0.1.8",
  "description": "A React plugin for c2pa-react-component that renders DIACC PCTF conformance assertion data.",
  "type": "module",
  "main": "./dist/c2pa-react-diacc-component.umd.cjs",
  "module": "./dist/c2pa-react-diacc-component.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/c2pa-react-diacc-component.js",
      "require": "./dist/c2pa-react-diacc-component.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/c2pa-react-diacc-component.css",
    "./dist/c2pa-react-diacc-component.css": "./dist/c2pa-react-diacc-component.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint src",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "dev:lib": "vite build --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matthewrappard/c2pa-react-diacc-component.git"
  },
  "keywords": [
    "c2pa",
    "diacc",
    "pctf",
    "conformance",
    "react",
    "component",
    "provenance",
    "content-credentials"
  ],
  "author": "Matthew Rappard",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "c2pa-react-component-types": "^0.1.0"
  }
}
